{
  "name": "cyber-fortune-tv",
  "version": "1.3.1",
  "description": "赛博抽抽机 — 复古像素电视抽签 / 万能随机决定器 (Electron)",
  "main": "src/main.js",
  "author": "LAZY_M",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac dmg",
    "dist:win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.lamecat.cyberfortunetv",
    "productName": "赛博抽抽机",
    "artifactName": "${name}-${version}-${os}.${ext}",
    "files": [
      "src/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns"
    },
    "dmg": {
      "title": "赛博抽抽机"
    },
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "赛博抽抽机"
    }
  }
}
